def bmi(weight,height):
    return round(weight/(height**2),2)

def bmi_category(weight,height):
    if bmi(weight,height) < 18.5:
        return "Underweight"
    elif 18.5 <= bmi(weight,height) < 25:
        return "Normal weight"
    elif 25 <= bmi(weight,height) < 30:
        return "Overweight"
    return "Obese"

